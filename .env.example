# =========================
# BandViz App Configuration
# =========================

# Database (required for app startup)
DB_USERNAME=bandviz
DB_PASSWORD=bandviz

# Jira integration (required for Jira sync + seeding)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# App-level Jira sync switches
JIRA_SYNC_ENABLED=false
JIRA_PROJECT_KEYS=CRM,ANA,MOB


# ==================================
# Global Jira Seeding Script Settings
# ==================================
# Used by: scripts/seed_from_jira.sh seed-global

# Required Atlassian org/site identifiers
ATLASSIAN_ORG_ID=your-atlassian-org-id
ATLASSIAN_SITE_ID=your-atlassian-site-id

# Select teams by names and/or ids (at least one of these is required)
ATLASSIAN_TEAM_NAMES=Collections BAU,Prod-Eng
ATLASSIAN_TEAM_IDS=

# Required mapping:
# key   = Atlassian team displayName OR teamId
# value = list of Jira project keys that team can work on
ATLASSIAN_TEAM_PROJECT_KEYS_JSON={"Collections BAU":["COLL","COLLTKT"],"Prod-Eng":["PE","OPS"]}

# Optional seed target URL
BANDVIZ_BASE_URL=http://localhost:8080

# Optional defaults for created/updated records
BANDVIZ_DEFAULT_DEVELOPER_ROLE=DEVELOPER
BANDVIZ_DEFAULT_WEEKLY_CAPACITY=40
BANDVIZ_DEFAULT_TARGET_UTILIZATION=70
BANDVIZ_DEFAULT_DELIVERY_MODE=HYBRID

# Duplicate user handling across multiple Atlassian teams: first | error
ATLASSIAN_DUPLICATE_USER_TEAM_STRATEGY=first

# Dry run mode: true | false
DRY_RUN=false
